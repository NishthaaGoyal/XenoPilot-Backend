# Environment Variables

# Required
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"

# Optional — enables AI-powered responses (falls back to smart mock if not set)
OPENAI_API_KEY=""

# Seed database on startup when empty
SEED_ON_STARTUP="true"

# Server port (Railway sets this automatically)
PORT=8000
